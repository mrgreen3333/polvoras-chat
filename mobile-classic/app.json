{
  "expo": {
    "name": "Pólvoras Chat Classic",
    "owner": "plvoras",
    "slug": "polvoras-chat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1A0D"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.polvoras.chat.classic"
    },
    "android": {
      "package": "com.polvoras.chat.classic",
      "versionCode": 1,
      "minSdkVersion": 21,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0D1A0D"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Pólvoras Chat Classic precisa de acesso à tua galeria para partilhar fotos.",
          "cameraPermission": "Pólvoras Chat Classic precisa de acesso à câmara para tirar fotos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#4CAF50",
          "androidMode": "default",
          "androidCollapsedTitle": "Pólvoras Chat Classic"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "d9f97543-d173-4da3-a1b9-eff6ad8892c6"
      }
    }
  }
}
